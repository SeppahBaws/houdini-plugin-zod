{
    "name": "houdini-plugin-zod",
    "version": "0.0.0",
    "description": "A plugin for Houdini which generates Zod types from your graphql schema.",
    "keywords": [
        "graphql",
        "houdini",
        "zod",
        "typescript"
    ],
    "homepage": "https://github.com/SeppahBaws/houdini-plugin-zod",
    "repository": {
        "type": "git",
        "url": "https://github.com/SeppahBaws/houdini-plugin-zod"
    },
    "license": "MIT",
    "type": "module",
    "scripts": {
        "changeset": "changeset",
        "build": "tsc",
        "format:check": "prettier --check .",
        "format:write": "prettier --write .",
        "lint": "eslint src/**/*.ts"
    },
    "files": [
        "build"
    ],
    "exports": {
        ".": {
            "import": "./build/index.js",
            "types": "./build/index.d.ts"
        }
    },
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "packageManager": "pnpm@10.14.0",
    "devDependencies": {
        "@changesets/cli": "^2.29.5",
        "eslint": "^9.29.0",
        "globals": "^16.2.0",
        "graphql": "^16.11.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.34.1"
    },
    "peerDependencies": {
        "houdini": "^1.5.0"
    },
    "dependencies": {
        "recast": "^0.23.11"
    }
}
